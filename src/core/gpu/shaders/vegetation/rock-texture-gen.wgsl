/**
 * rock-texture-gen.wgsl — Procedural Rock Texture Generation Compute Shader
 *
 * Generates two 128×128 rgba8unorm textures for procedural rocks:
 *
 * Pass 0 (Albedo + AO):
 *   RGB: Base color from fallbackColor + noise-driven tint variation + moss on top faces
 *   A:   Ambient occlusion (1.0 = fully lit, darker in concavities)
 *
 * Pass 1 (Normal Map):
 *   RGB: Tangent-space micro-detail normals from high-frequency noise gradient
 *   A:   1.0 (unused)
 *
 * Each texel maps to a spherical direction via equirectangular projection (matching
 * the spherical UVs generated by rock-mesh-gen.wgsl). The noise functions are
 * shared with rock-mesh-gen.wgsl for consistency.
 *
 * Dispatched as @workgroup_size(8, 8), with 16×16 workgroups for 128×128 texture.
 */

// ==================== Uniforms ====================

struct RockTexParams {
  seed: f32,              // Must match the mesh generation seed
  baseColor: vec3f,       // Fallback color from PlantType.color (linear space)
  mossThreshold: f32,     // Normal.y threshold for moss blending (default 0.6)
  mossStrength: f32,      // How much moss color to blend (default 0.4)
  aoStrength: f32,        // Ambient occlusion intensity (default 0.5)
  passIndex: u32,         // 0 = albedo+AO, 1 = normal map
  textureSize: u32,       // Texture dimension (128)
  _pad0: f32,
  _pad1: f32,
  _pad2: f32,
}

@group(0) @binding(0) var<uniform> params: RockTexParams;
@group(0) @binding(1) var outputTexture: texture_storage_2d<rgba8unorm, write>;

// ==================== Constants ====================

const PI: f32 = 3.14159265;

// ==================== Hash Functions ====================

fn hash3(p: vec3f) -> vec3f {
  var q = vec3f(
    dot(p, vec3f(127.1, 311.7, 74.7)),
    dot(p, vec3f(269.5, 183.3, 246.1)),
    dot(p, vec3f(113.5, 271.9, 124.6))
  );
  return fract(sin(q + params.seed) * 43758.5453123);
}

// ==================== Perlin Noise (3D) ====================

fn fade(t: vec3f) -> vec3f {
  return t * t * t * (t * (t * 6.0 - 15.0) + 10.0);
}

fn gradientHash(p: vec3f) -> vec3f {
  let h = hash3(p);
  return normalize(h * 2.0 - 1.0);
}

fn perlinNoise(p: vec3f) -> f32 {
  let pi = floor(p);
  let pf = p - pi;
  let w = fade(pf);

  let g000 = dot(gradientHash(pi + vec3f(0, 0, 0)), pf - vec3f(0, 0, 0));
  let g100 = dot(gradientHash(pi + vec3f(1, 0, 0)), pf - vec3f(1, 0, 0));
  let g010 = dot(gradientHash(pi + vec3f(0, 1, 0)), pf - vec3f(0, 1, 0));
  let g110 = dot(gradientHash(pi + vec3f(1, 1, 0)), pf - vec3f(1, 1, 0));
  let g001 = dot(gradientHash(pi + vec3f(0, 0, 1)), pf - vec3f(0, 0, 1));
  let g101 = dot(gradientHash(pi + vec3f(1, 0, 1)), pf - vec3f(1, 0, 1));
  let g011 = dot(gradientHash(pi + vec3f(0, 1, 1)), pf - vec3f(0, 1, 1));
  let g111 = dot(gradientHash(pi + vec3f(1, 1, 1)), pf - vec3f(1, 1, 1));

  let x00 = mix(g000, g100, w.x);
  let x10 = mix(g010, g110, w.x);
  let x01 = mix(g001, g101, w.x);
  let x11 = mix(g011, g111, w.x);
  let y0 = mix(x00, x10, w.y);
  let y1 = mix(x01, x11, w.y);
  return mix(y0, y1, w.z);
}

fn perlinFBM(p: vec3f, octaves: i32) -> f32 {
  var sum = 0.0;
  var freq = 1.0;
  var amp = 0.5;
  var total = 0.0;
  for (var i = 0; i < octaves; i++) {
    sum += perlinNoise(p * freq) * amp;
    total += amp;
    freq *= 2.0;
    amp *= 0.5;
  }
  return sum / total;
}

// ==================== Worley/Voronoi Noise ====================

fn worleyF1F2(p: vec3f) -> vec2f {
  let pi = floor(p);
  let pf = fract(p);
  var f1 = 999.0;
  var f2 = 999.0;
  for (var x = -1; x <= 1; x++) {
    for (var y = -1; y <= 1; y++) {
      for (var z = -1; z <= 1; z++) {
        let offset = vec3f(f32(x), f32(y), f32(z));
        let cellPoint = hash3(pi + offset);
        let diff = offset + cellPoint - pf;
        let dist = length(diff);
        if (dist < f1) { f2 = f1; f1 = dist; }
        else if (dist < f2) { f2 = dist; }
      }
    }
  }
  return vec2f(f1, f2);
}

fn voronoiRidge(p: vec3f) -> f32 {
  let f = worleyF1F2(p);
  return saturate(f.y - f.x);
}

// ==================== Rock Displacement (same as rock-mesh-gen.wgsl) ====================

fn domainWarpedFBM(p: vec3f) -> f32 {
  let warp = vec3f(
    perlinFBM(p + vec3f(100.0, 0.0, 0.0), 3),
    perlinFBM(p + vec3f(0.0, 200.0, 0.0), 3),
    perlinFBM(p + vec3f(0.0, 0.0, 300.0), 3)
  ) * 0.3;
  return perlinFBM((p + warp) * 4.0, 3);
}

fn turbulenceNoise(p: vec3f) -> f32 {
  var sum = 0.0;
  var amp = 0.5;
  var freq = 1.0;
  var total = 0.0;
  for (var i = 0; i < 3; i++) {
    sum += abs(perlinNoise(p * freq)) * amp;
    total += amp;
    freq *= 2.0;
    amp *= 0.5;
  }
  return sum / total;
}

fn rockDisplacement(dir: vec3f) -> f32 {
  let p = dir * 3.0 + params.seed * 17.0;
  let ridge = voronoiRidge(p * 2.0);
  let fbm = domainWarpedFBM(p) * 0.5 + 0.5;
  let turb = turbulenceNoise(p * 6.0);
  let combined = ridge * 0.6 + fbm * 0.25 + turb * 0.15;
  return combined * 1.3 - 0.3;
}

// ==================== UV → Direction Mapping ====================

/**
 * Convert equirectangular UV (0-1) to a 3D unit sphere direction.
 * Inverse of the sphericalUV() function in rock-mesh-gen.wgsl.
 */
fn uvToDirection(uv: vec2f) -> vec3f {
  let theta = (uv.x - 0.5) * 2.0 * PI; // -π to π
  let phi = (uv.y - 0.5) * PI;          // -π/2 to π/2

  let cosP = cos(phi);
  return vec3f(
    cosP * cos(theta),
    sin(phi),
    cosP * sin(theta)
  );
}

// ==================== Albedo + AO Pass ====================

fn generateAlbedoAO(uv: vec2f) -> vec4f {
  let dir = uvToDirection(uv);
  let p = dir * 3.0 + params.seed * 17.0;

  // --- Base color with noise-driven tint variation ---
  // Low-frequency noise for warm/cool color shifts across the rock surface
  let tintNoise = perlinFBM(p * 1.5 + vec3f(500.0, 0.0, 0.0), 2);
  let warmShift = vec3f(0.05, 0.02, -0.03) * tintNoise;
  let coolShift = vec3f(-0.02, 0.0, 0.04) * (1.0 - tintNoise);
  var color = params.baseColor + warmShift + coolShift;

  // Medium-frequency noise for surface detail color variation
  let detailNoise = perlinFBM(p * 4.0, 3) * 0.5 + 0.5;
  color *= mix(0.85, 1.15, detailNoise);

  // --- Moss/lichen on upward-facing surfaces ---
  let mossColor = vec3f(0.15, 0.25, 0.08); // Dark olive-green moss
  let mossNoise = perlinFBM(p * 3.0 + vec3f(0.0, 800.0, 0.0), 3) * 0.5 + 0.5;
  let upFacing = dir.y; // -1 (bottom) to +1 (top)

  // Moss appears on top faces, modulated by patchy noise
  let mossFactor = smoothstep(params.mossThreshold - 0.1, params.mossThreshold + 0.2, upFacing)
                 * smoothstep(0.3, 0.7, mossNoise)
                 * params.mossStrength;
  color = mix(color, mossColor, mossFactor);

  // --- Ambient Occlusion from displacement concavity ---
  // Evaluate displacement to find crevices (low displacement = concavity)
  let displacement = rockDisplacement(dir);
  // Remap: negative displacement = deep concavity = dark AO
  let ao = saturate(displacement * 1.5 + 0.7) * (1.0 - params.aoStrength)
         + params.aoStrength * 0.3; // Minimum AO floor
  let finalAO = mix(0.3, 1.0, saturate(ao));

  // Darken crevices in the color itself for baked-in shadow
  color *= mix(0.6, 1.0, saturate(displacement * 0.8 + 0.6));

  // Clamp color to valid range
  color = clamp(color, vec3f(0.0), vec3f(1.0));

  return vec4f(color, finalAO);
}

// ==================== Normal Map Pass ====================

fn generateNormalMap(uv: vec2f) -> vec4f {
  let dir = uvToDirection(uv);
  let p = dir * 3.0 + params.seed * 17.0;

  // High-frequency noise for micro-detail that geometry can't capture
  let eps = 0.005;
  let freq = 12.0;

  // Evaluate noise at offset positions to compute gradient
  let center = perlinFBM(p * freq, 4);
  let dx = perlinFBM((p + vec3f(eps, 0.0, 0.0)) * freq, 4) - center;
  let dy = perlinFBM((p + vec3f(0.0, eps, 0.0)) * freq, 4) - center;

  // Tangent-space normal perturbation
  // Scale controls the "bumpiness" — higher = more pronounced micro-detail
  let bumpScale = 2.0;
  let tangentNormal = normalize(vec3f(
    -dx * bumpScale,
    -dy * bumpScale,
    1.0 / eps
  ));

  // Normalize and pack to [0, 1] range for rgba8unorm storage
  let packed = tangentNormal * 0.5 + 0.5;

  return vec4f(packed, 1.0);
}

// ==================== Main Entry Point ====================

@compute @workgroup_size(8, 8)
fn main(@builtin(global_invocation_id) gid: vec3u) {
  let size = params.textureSize;
  if (gid.x >= size || gid.y >= size) {
    return;
  }

  // Compute UV from texel coordinates (center of texel)
  let uv = (vec2f(gid.xy) + 0.5) / f32(size);

  var result: vec4f;
  if (params.passIndex == 0u) {
    result = generateAlbedoAO(uv);
  } else {
    result = generateNormalMap(uv);
  }

  textureStore(outputTexture, vec2i(gid.xy), result);
}
